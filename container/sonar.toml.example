# Nyx — Sonar configuration
# This file is baked into the image at /app/sonar.toml.default and used
# automatically. To override, copy to secrets/sonar.toml (host) and it will
# be bind-mounted at /config/sonar.toml — entrypoint.sh switches SONAR_CONFIG
# to the user copy when it exists.
#
# Sonar is installed into the Nyx runtime layer under /opt/sonar/bin (for
# example /opt/sonar/bin/sonar-mcp). Those binaries are also exported on PATH,
# but Nyx prefers the absolute /opt/sonar/bin path in MCP config.
# The default Nyx wiring keeps Sonar MCP-first and points it at the internal
# SearXNG sidecar service.

[searxng]
base_url = "http://searxng:8080"

[database]
path = "/data/sonar.sqlite"

[http]
host = "0.0.0.0"
port = 8001
auth_mode = "none"

[cache]
search_ttl_seconds = 900
extract_ttl_seconds = 86400

[fetch]
connect_timeout_seconds = 10.0
read_timeout_seconds = 20.0
max_body_bytes = 2097152
user_agent = "Sonar/0.1"

[search]
default_limit = 8
max_limit = 20

[ranking.domain_priors]
"docs.python.org" = 0.35
"wikipedia.org" = 0.10

[secrets]
overlay_path = "/config/sonar.secrets.toml"
